[user]
	name = brijshah
	email = brijshah0@gmail.com

[core]
    editor = code
    autocrlf = input
    excludesfile = ~/.config/git/ignore

[init]
    defaultBranch = main

[pull]
    rebase = true

[push]
    autoSetupRemote = true

[rebase]
    autoStash = true

[merge]
    conflictstyle = diff3

[diff]
    algorithm = histogram
    colorMoved = default

[fetch]
    prune = true

[color]
    ui = auto

[alias]
    lg = log --oneline --graph --decorate --all
    st = status -sb
