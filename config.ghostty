# Typography
font-size = 11.5
font-thicken = true

# Theme
theme = "Catppuccin Frappe"

# Window and Appearance
background-opacity = 0.9

# Cursor
cursor-style = bar
cursor-style-blink = true
cursor-opacity = 0.8

# Mouse
mouse-hide-while-typing = true
copy-on-select = clipboard

# Performance
scrollback-limit = 25000000
